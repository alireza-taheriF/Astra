# ============================================================================
# Astra — environment variables (template)
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. The frontend reads NEXT_PUBLIC_* at build/runtime;
# the backend reads the server-only keys.
# ============================================================================

# ---- Supabase (shared) ----
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe for the browser; access is gated by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
# Used by the FastAPI backend (badge read + capability_scores writes).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: backend also accepts SUPABASE_URL as an alias for the project URL.
# SUPABASE_URL=

# ---- Backend tunables (optional; defaults shown) ----
# Score version — bumping this busts the in-process badge cache.
ASTRA_SCORE_VERSION=v1.0
# Per-IP badge rate limit (requests per window) for direct, non-camo hits.
ASTRA_BADGE_RATE_LIMIT=10
ASTRA_BADGE_RATE_WINDOW=1.0
# In-process slug cache size.
ASTRA_BADGE_CACHE_SIZE=5000
