# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe for the browser; access gated by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by the FastAPI backend to write capability_scores (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=
